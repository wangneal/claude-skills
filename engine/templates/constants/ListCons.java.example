    /** 最大每页记录数 */
    public static final int MAX_PAGE_SIZE = 1000;

    /** 最小每页记录数 */
    public static final int MIN_PAGE_SIZE = 1;

    // ===== 主键字段 =====

    /** 主键 */
    public static final String KEY_ID = "id";


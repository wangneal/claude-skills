package ${PACKAGE_NAME};

/**
 * 列表常量类
 * 用于定义列表字段键值、排序字段、过滤字段等常量
 *
 * <p>说明：此类用于定义列表插件中使用的字段常量、排序规则和过滤条件</p>
 *
 * <p>创建日期：${DATE}</p>
 * <p>作者：${AUTHOR}</p>
 * <p>版本：1.0</p>
 */
public class ListCons {

    // ===== 分页常量 =====

    /** 默认每页记录数 */
